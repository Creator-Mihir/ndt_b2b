# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/conex

# JWT Secrets
JWT_SECRET=supersecretjwtkeychangeinproduction
JWT_EXPIRES_IN=7d

# Third Party Services (Add credentials as needed)
